# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════
DATABASE_URL="postgresql://homelab:password@localhost:5432/homelab_dashboard"

# ═══════════════════════════════════════════
# CACHE
# ═══════════════════════════════════════════
REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════
# AUTHENTIFICATION (session légère, sans NextAuth)
# Générer NEXTAUTH_SECRET avec : openssl rand -base64 32
# Générer ENCRYPTION_KEY avec : openssl rand -base64 32
# ═══════════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
ADMIN_EMAIL="admin@homelab.local"
ADMIN_PASSWORD_HASH="bcrypt-hash-of-your-password"

# ── Login dashboard (session cookie légère) ──────────────────
# Identifiants de connexion — côté serveur uniquement (jamais NEXT_PUBLIC_)
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="changeme"
# Durée de session en secondes (86400 = 24h)
DASHBOARD_SESSION_DURATION="86400"

# ═══════════════════════════════════════════
# CHIFFREMENT (tokens API stockés en DB)
# AES-256-GCM — 32 bytes en base64
# ═══════════════════════════════════════════
ENCRYPTION_KEY="change-me-generate-with-openssl-rand-base64-32"

# ═══════════════════════════════════════════
# INTÉGRATIONS (configurables aussi via UI settings)
# Les tokens sont stockés chiffrés en DB si configurés via l'UI
# Ces variables d'env servent de fallback/initialisation
# ═══════════════════════════════════════════

# Home Assistant
HOME_ASSISTANT_URL="http://homeassistant.local:8123"
HOME_ASSISTANT_TOKEN=""

# Vikunja (gestionnaire de tâches)
VIKUNJA_URL="http://vikunja.homelab.local"
VIKUNJA_TOKEN=""

# N8N (automatisation)
N8N_URL="http://n8n.homelab.local"
N8N_API_KEY=""

# Docmost (wiki/notes)
DOCMOST_URL="http://docmost.homelab.local"

# Actual Budget (finances)
ACTUAL_URL="http://actual.homelab.local"

# Ollama (LLM local)
OLLAMA_URL="http://localhost:11434"

# ═══════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════
NEXT_PUBLIC_APP_NAME="Homelab Dashboard"
NEXT_PUBLIC_APP_URL="https://dashboard.tondomaine.com"

# Environnement (development | production)
NODE_ENV="development"

# ═══════════════════════════════════════════
# WIDGETS — CLÉS PUBLIQUES OPTIONNELLES
# ═══════════════════════════════════════════

# Grafana : pré-remplit le champ URL dans le widget Grafana Panel
# (optionnel, configurable aussi directement dans le widget)
NEXT_PUBLIC_GRAFANA_URL=http://192.168.1.x:3000

# OpenWeatherMap : requis pour le widget Météo
# Clé gratuite sur https://openweathermap.org/api (1000 calls/jour)
NEXT_PUBLIC_OPENWEATHER_API_KEY=
